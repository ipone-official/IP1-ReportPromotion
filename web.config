<?xml version="1.0" encoding="utf-8"?>
<!--
  Minimal web.config - rewrite rule is configured in IIS GUI (URL Rewrite).
  If this file still causes 500, rename to web.config.bak and use IIS GUI only.
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="ProxyToBot" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:3000/{R:1}" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
