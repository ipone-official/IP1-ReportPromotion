<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS app alias: line-promo-bot
  Webhook URL:  https://portal.ip-one.com/line-promo-bot/webhook
  Node (PM2):   http://localhost:3000

  Prerequisites:
  - URL Rewrite + ARR (Enable proxy at server level)
  - Allowed Server Variables: HTTP_X_FORWARDED_PROTO, HTTP_X_FORWARDED_HOST
  - App pool: No Managed Code, Started
  - Do NOT put <authentication> here (locked at parent site level)
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="ProxyToBot" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:3000/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
            <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
          </serverVariables>
        </rule>
      </rules>
      <allowedServerVariables>
        <add name="HTTP_X_FORWARDED_PROTO" />
        <add name="HTTP_X_FORWARDED_HOST" />
      </allowedServerVariables>
    </rewrite>
  </system.webServer>
</configuration>
