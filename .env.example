# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (ห้าม commit .env)

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# AI (DeepSeek เป็นหลัก; ใส่ DEEPSEEK_API_KEY แล้วใช้ DeepSeek)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# (สำรอง) ถ้าใช้ OpenAI แทน
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# SQL Server (master + บันทึกรายงาน) — ว่างได้ถ้ายังไม่ต่อ DB (โหมด demo)
DB_SERVER=
DB_DATABASE=
DB_USER=
DB_PASSWORD=
DB_PORT=1433

# เซิร์ฟเวอร์
PORT=3000
# URL สาธารณะของบอท (สำหรับลิงก์รูป/เว็บฮุค) เช่น https://xxxx.ngrok-free.dev
PUBLIC_URL=
