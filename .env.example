# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (ห้าม commit .env)

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# AI (DeepSeek เป็นหลัก; ใส่ DEEPSEEK_API_KEY แล้วใช้ DeepSeek)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat


# SQL Server (master + บันทึกรายงาน) — จำเป็น: บอทต้องต่อ DB ได้ถึงจะตอบ (masterReady gate)
DB_SERVER=
DB_DATABASE=
DB_USER=
DB_PASSWORD=
DB_PORT=1433

# Redis — จำเป็น (hard dependency): BullMQ queue + session/photo/AI cache (โค้ดใช้ 5 จุด)
REDIS_URL=redis://127.0.0.1:6379

# Meilisearch — typo-tolerant search (match ร้าน/ยี่ห้อ); MEILI_MASTER_KEY ต้องตรงกับ service
MEILI_HOST=http://127.0.0.1:7700
MEILI_MASTER_KEY=

# ปรับแต่ง (มี default ในโค้ดแล้ว ใส่เฉพาะถ้าจะ override)
WORKER_CONCURRENCY=5
LINE_PROFILE_TIMEOUT_MS=2500

# เซิร์ฟเวอร์ (Node ฟัง PORT นี้ — IIS proxy มาที่นี่ ไม่ใช่ 443)
PORT=3000
# URL สาธารณะ base ของ IIS app (ไม่มี /webhook ท้าย URL)
# production: https://portal.ip-one.com/line-promo-bot
PUBLIC_URL=https://portal.ip-one.com/line-promo-bot
